# configuration commands
auto-reload yes
bookmark-cmd "buku"
browser "open -g -a 'librewolf' %u"
confirm-exit yes
datetime-format %Y-%m-%d
display-article-progress yes
external-url-viewer "urlview"
feedlist-format "%i %t %d | %u #%T"
openbrowser-and-mark-jumps-to-next-unread yes
text-width 60

# binds
bind-key G end
bind-key J next-feed articlelist
bind-key K prev-feed articlelist
bind-key Q hard-quit
bind-key f goto-url
bind-key g home
bind-key h quit
bind-key j down
bind-key j next articlelist
bind-key k prev articlelist
bind-key k up
bind-key l open

# macro setup
browser linkhandler
macro , open-in-browser

# launch video player
macro v set browser "setsid -f mpv" ; open-in-browser ; set browser linkhandler

# download video
macro d set browser "yt-dlp"; open-in-browser ; set browser linkhandler

# download audio only
macro a set browser "yt-dlp --embed-medatada -xic -f bestaudio/best" ; open-in-browser ; set browser linkhandler
